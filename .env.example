# Copy this file to .env.local and fill in your own keys.
# .env.local is gitignored and never committed.

# Financial Modeling Prep API key (required for skills/_shared/fmp-client)
# Free tier: 250 calls/day
# Get your free API key at: https://site.financialmodelingprep.com/developer/docs
# 1. Sign up for a free account
# 2. Navigate to Dashboard → API Keys
# 3. Copy your API key and paste below
FMP_API_KEY=

# Optional: other data provider keys (only if you wire them up)
# ALPHAVANTAGE_API_KEY=
# POLYGON_API_KEY=
